{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "declaration": true,
    "outDir": "dist",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": [
    "index.ts",
    "types.ts",
    "tracker.ts",
    "budget.ts",
    "pricing.ts",
    "compressor.ts",
    "estimator.ts",
    "circuit-breaker.ts",
    "router.ts",
    "checkpoint.ts",
    "events.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
